# Server
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=boarderswatch_secret_key_change_in_production

# Database (SQLite file path)
DB_PATH=./data/boarderswatch.db

# Twilio (SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# SendGrid (Email)
SENDGRID_API_KEY=

# Camera RTSP relay (if needed)
RTSP_RELAY_PORT=8554
